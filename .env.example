KALSHI_API_KEY_ID=your_api_key_id_here

# Local dev: point to the PEM file
KALSHI_PRIVATE_KEY_PATH=./private_key.pem

# Cloud deploy (Railway/Render): paste the raw PEM contents as a single env var instead.
# If this is set, KALSHI_PRIVATE_KEY_PATH is ignored.
# KALSHI_PRIVATE_KEY_CONTENTS="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Strategy config
EDGE_THRESHOLD=0.05        # min model-vs-market gap to trade (5%)
KELLY_FRACTION=0.25        # fraction of full Kelly to bet (25% = conservative)
MAX_POSITION_DOLLARS=50    # max $ per market
MAX_TOTAL_EXPOSURE_DOLLARS=500  # max $ across all open positions

# Set to false only when ready for live trading
DRY_RUN=true

POLL_INTERVAL_SECONDS=60

# Goals bot config
GOALS_TRADE_MIN=72          # start of trade window (minutes into match)
GOALS_TRADE_MAX=78          # end of trade window
ADDED_TIME_ESTIMATE=4       # assumed injury time added to 90 min
GOALS_EDGE_THRESHOLD=0.05   # min edge to trade goals markets
